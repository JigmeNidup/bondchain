generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String      @id @default(cuid())
  didKey              String      @unique
  privyWalletId       String
  privyWalletAddress  String
  cidHash             String?
  fullName            String?
  linkageHash         String      @unique
  createdAt           DateTime    @default(now())
  documents           Document[]  @relation("UserDocuments")
  signatures          Signature[] @relation("UserSignatures")
  peerRequests        PeerSigningRequest[] @relation("PeerRequestRequester")
  agencyRequests      AgencyServiceRequest[] @relation("CitizenAgencyRequests")
}

model Document {
  id                  String      @id @default(cuid())
  ipfsCid             String
  fileName            String?
  mimeType            String?
  docHash             String
  ownerDid            String
  ownerWallet         String
  txHash              String?
  createdAt           DateTime    @default(now())
  owner               User        @relation("UserDocuments", fields: [ownerDid], references: [didKey])
  peerRequests        PeerSigningRequest[]
  agencyRequests      AgencyServiceRequest[]
  issuedCertificates  AgencyIssuedCertificate[]

  @@index([docHash])
}

model Signature {
  id                  String      @id @default(cuid())
  docHash             String
  signerDid           String
  signerWallet        String
  signerWalletHash    String
  payloadHash         String
  previousSignatureHash String
  signature           String
  signatureHash       String      @unique
  txHash              String
  createdAt           DateTime    @default(now())
  signer              User        @relation("UserSignatures", fields: [signerDid], references: [didKey])
}

model Workflow {
  id                  String      @id @default(cuid())
  docHash             String
  serviceId           String?
  currentStep         Int         @default(0)
  status              String      @default("PENDING")
  createdByDid        String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  steps               WorkflowStep[]
}

model WorkflowStep {
  id                  String      @id @default(cuid())
  workflowId          String
  stepNumber          Int
  signerDid           String
  action              String
  txHash              String?
  reason              String?
  createdAt           DateTime    @default(now())
  workflow            Workflow    @relation(fields: [workflowId], references: [id])
}

model SigningSession {
  id                  String      @id @default(cuid())
  token               String      @unique
  documentHash        String
  previousSignatureHash String?
  documentName        String?
  callbackUrl         String
  status              String      @default("PENDING")
  signatureHash       String?
  txHash              String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model PeerSigningRequest {
  id                    String    @id @default(cuid())
  token                 String    @unique
  documentId            String
  docHash               String
  requesterDid          String
  requesterEmail        String
  targetEmail           String
  targetCidHash         String
  requesterSignatureHash String
  targetSignatureHash   String?
  status                String    @default("PENDING")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  signedAt              DateTime?
  document              Document  @relation(fields: [documentId], references: [id])
  requester             User      @relation("PeerRequestRequester", fields: [requesterDid], references: [didKey])

  @@index([requesterDid])
  @@index([targetCidHash])
  @@index([docHash])
  @@index([documentId])
}

model Agency {
  id                  String      @id @default(cuid())
  name                String
  status              String      @default("INVITED")
  adminEmail          String
  adminCidHash        String
  adminDid            String?
  createdByDid        String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  invitations         AgencyInvitation[]
  members             AgencyMember[]
  services            AgencyService[]

  @@index([status])
}

model AgencyInvitation {
  id                  String      @id @default(cuid())
  token               String      @unique
  agencyId            String
  email               String
  cidHash             String
  status              String      @default("PENDING")
  acceptedByDid       String?
  acceptedAt          DateTime?
  createdAt           DateTime    @default(now())
  agency              Agency      @relation(fields: [agencyId], references: [id])

  @@index([agencyId])
}

model AgencyMember {
  id                  String      @id @default(cuid())
  agencyId            String
  didKey              String
  email               String
  cidHash             String?
  role                String
  status              String      @default("ACTIVE")
  createdAt           DateTime    @default(now())
  agency              Agency      @relation(fields: [agencyId], references: [id])
  assignedSteps       AgencyServiceWorkflowStep[]
  requestSteps        AgencyRequestStep[]

  @@unique([agencyId, didKey])
  @@index([didKey])
  @@index([agencyId, role])
}

model AgencyOfficerInvitation {
  id                  String      @id @default(cuid())
  token               String      @unique
  agencyId            String
  email               String
  cidHash             String
  status              String      @default("PENDING")
  acceptedByDid       String?
  acceptedAt          DateTime?
  createdAt           DateTime    @default(now())

  @@index([agencyId])
}

model AgencyService {
  id                  String      @id @default(cuid())
  agencyId            String
  name                String
  description         String?
  requirementMode     String      @default("DOCUMENT_REQUIRED")
  active              Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  agency              Agency      @relation(fields: [agencyId], references: [id])
  workflowSteps       AgencyServiceWorkflowStep[]
  requests            AgencyServiceRequest[]

  @@index([agencyId])
  @@index([active])
}

model AgencyServiceWorkflowStep {
  id                  String      @id @default(cuid())
  serviceId           String
  stepNumber          Int
  role                String
  memberId            String
  createdAt           DateTime    @default(now())
  service             AgencyService @relation(fields: [serviceId], references: [id])
  member              AgencyMember @relation(fields: [memberId], references: [id])

  @@unique([serviceId, stepNumber])
  @@index([memberId])
}

model AgencyServiceRequest {
  id                  String      @id @default(cuid())
  token               String      @unique
  serviceId           String
  citizenDid          String
  citizenEmail        String?
  metadataJson        String
  documentId          String?
  docHash             String?
  citizenSignatureHash String?
  latestSignatureHash String?
  status              String      @default("PENDING")
  currentStepNumber   Int         @default(1)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  completedAt         DateTime?
  service             AgencyService @relation(fields: [serviceId], references: [id])
  citizen             User        @relation("CitizenAgencyRequests", fields: [citizenDid], references: [didKey])
  document            Document?   @relation(fields: [documentId], references: [id])
  steps               AgencyRequestStep[]
  certificate         AgencyIssuedCertificate?

  @@index([serviceId])
  @@index([citizenDid])
  @@index([status])
}

model AgencyRequestStep {
  id                  String      @id @default(cuid())
  requestId           String
  stepNumber          Int
  role                String
  memberId            String
  actionToken         String      @unique
  status              String      @default("PENDING")
  signatureHash       String?
  txHash              String?
  reason              String?
  createdAt           DateTime    @default(now())
  actedAt             DateTime?
  request             AgencyServiceRequest @relation(fields: [requestId], references: [id])
  member              AgencyMember @relation(fields: [memberId], references: [id])

  @@unique([requestId, stepNumber])
  @@index([memberId])
  @@index([requestId, status])
}

model AgencyIssuedCertificate {
  id                  String      @id @default(cuid())
  requestId           String      @unique
  documentId          String
  signatureHash       String?
  credentialStatus    String      @default("PENDING")
  credInviteUrl       String?
  deepLinkUrl         String?
  issueCredThreadId   String?
  relationshipDid     String?
  revocationId        String?
  createdAt           DateTime    @default(now())
  request             AgencyServiceRequest @relation(fields: [requestId], references: [id])
  document            Document    @relation(fields: [documentId], references: [id])
}
